rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/Users/$(request.auth.uid)).data;
    }

    function currentUserRole() {
      return currentUserData().role;
    }

    function isManagement() {
      return signedIn() && currentUserRole() == 'management';
    }

    function isValidRole(role) {
      return role in ['projectLeader', 'management', 'employee'];
    }

    function isProjectLeader() {
      return signedIn() && currentUserRole() == 'projectLeader';
    }

    function isEmployee() {
      return signedIn() && currentUserRole() == 'employee';
    }

    function canReadUser(userId) {
      return isSelf(userId)
        || isManagement()
        || isProjectLeader()
        || (isEmployee() && resource.data.role == 'projectLeader');
    }

    function isValidProjectStatus(status) {
      return status in ['active', 'paused', 'finished'];
    }

    function isProjectLeaderUser(userId) {
      return get(/databases/$(database)/documents/Users/$(userId)).data.role == 'projectLeader';
    }

    function isValidProjectCreate() {
      let data = request.resource.data;
      return data.keys().hasAll(['name', 'description', 'projectLeaderId', 'status', 'createdAt', 'updatedAt'])
        && data.keys().hasOnly(['name', 'description', 'projectLeaderId', 'status', 'createdAt', 'updatedAt'])
        && data.name is string
        && data.name.size() > 0
        && data.description is string
        && data.description.size() > 0
        && data.projectLeaderId is string
        && data.projectLeaderId.size() > 0
        && data.status == 'active'
        && isValidProjectStatus(data.status)
        && isProjectLeaderUser(data.projectLeaderId)
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidProjectUpdate() {
      let data = request.resource.data;
      let diff = request.resource.data.diff(resource.data);
      return diff.affectedKeys().hasOnly(['name', 'description', 'projectLeaderId', 'status', 'updatedAt'])
        && data.name is string
        && data.name.size() > 0
        && data.description is string
        && data.description.size() > 0
        && data.projectLeaderId is string
        && data.projectLeaderId.size() > 0
        && isValidProjectStatus(data.status)
        && isProjectLeaderUser(data.projectLeaderId)
        && data.createdAt == resource.data.createdAt
        && data.updatedAt == request.time;
    }

    function isValidProjectUpdatedAtTouch() {
      let data = request.resource.data;
      let diff = request.resource.data.diff(resource.data);
      return diff.affectedKeys().hasOnly(['updatedAt'])
        && data.updatedAt == request.time
        && data.name == resource.data.name
        && data.description == resource.data.description
        && data.projectLeaderId == resource.data.projectLeaderId
        && data.status == resource.data.status
        && data.createdAt == resource.data.createdAt
        && (
          (isProjectLeader() && resource.data.projectLeaderId == request.auth.uid)
          || isEmployee()
        );
    }

    function ownsProject(projectId) {
      return get(/databases/$(database)/documents/Projects/$(projectId)).data.projectLeaderId == request.auth.uid;
    }

    function isValidTaskStatus(status) {
      return status in ['not_started', 'in_progress', 'pending_approval', 'approved'];
    }

    function isValidTaskPriority(priority) {
      return priority in ['low', 'medium', 'high', 'critical'];
    }

    function isEmployeeUser(userId) {
      return get(/databases/$(database)/documents/Users/$(userId)).data.role == 'employee';
    }

    function isValidTaskCreate() {
      let data = request.resource.data;
      return data.keys().hasAll([
          'title',
          'description',
          'priority',
          'status',
          'projectId',
          'assignedEmployeeId',
          'createdBy',
          'createdAt',
          'updatedAt',
          'approvedBy',
          'approvedAt',
        ])
        && data.keys().hasOnly([
          'title',
          'description',
          'priority',
          'status',
          'projectId',
          'assignedEmployeeId',
          'createdBy',
          'createdAt',
          'updatedAt',
          'approvedBy',
          'approvedAt',
        ])
        && data.title is string
        && data.title.size() > 0
        && data.description is string
        && data.description.size() > 0
        && isValidTaskPriority(data.priority)
        && isValidTaskStatus(data.status)
        && data.projectId is string
        && data.projectId.size() > 0
        && data.assignedEmployeeId is string
        && data.assignedEmployeeId.size() > 0
        && data.createdBy is string
        && data.createdBy.size() > 0
        && data.createdBy == request.auth.uid
        && isEmployeeUser(data.assignedEmployeeId)
        && ownsProject(data.projectId)
        && data.approvedBy == null
        && data.approvedAt == null
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isAssignedEmployeeTask() {
      return isEmployee() && resource.data.assignedEmployeeId == request.auth.uid;
    }

    function isTaskProjectLeader() {
      return isProjectLeader() && ownsProject(resource.data.projectId);
    }

    function isValidEmployeeTaskStatusUpdate() {
      let data = request.resource.data;
      let diff = request.resource.data.diff(resource.data);
      return isAssignedEmployeeTask()
        && resource.data.status != 'approved'
        && diff.affectedKeys().hasOnly(['status', 'updatedAt'])
        && isValidTaskStatus(data.status)
        && data.updatedAt == request.time
        && data.title == resource.data.title
        && data.description == resource.data.description
        && data.priority == resource.data.priority
        && data.projectId == resource.data.projectId
        && data.assignedEmployeeId == resource.data.assignedEmployeeId
        && data.createdBy == resource.data.createdBy
        && data.createdAt == resource.data.createdAt
        && data.approvedBy == resource.data.approvedBy
        && data.approvedAt == resource.data.approvedAt
        && (
          (resource.data.status == 'not_started' && data.status == 'in_progress')
          || (resource.data.status == 'in_progress' && data.status == 'pending_approval')
          || (resource.data.status == 'in_progress' && data.status == 'not_started')
          || (resource.data.status == 'pending_approval' && data.status == 'in_progress')
        );
    }

    function isValidEmployeeTaskUpdatedAtTouch() {
      let data = request.resource.data;
      let diff = request.resource.data.diff(resource.data);
      return isAssignedEmployeeTask()
        && resource.data.status == 'in_progress'
        && diff.affectedKeys().hasOnly(['updatedAt'])
        && data.updatedAt == request.time
        && data.title == resource.data.title
        && data.description == resource.data.description
        && data.priority == resource.data.priority
        && data.status == resource.data.status
        && data.projectId == resource.data.projectId
        && data.assignedEmployeeId == resource.data.assignedEmployeeId
        && data.createdBy == resource.data.createdBy
        && data.createdAt == resource.data.createdAt
        && data.approvedBy == resource.data.approvedBy
        && data.approvedAt == resource.data.approvedAt;
    }

    function isValidProjectLeaderTaskRejection() {
      let data = request.resource.data;
      let diff = request.resource.data.diff(resource.data);
      return isTaskProjectLeader()
        && resource.data.status == 'pending_approval'
        && data.status == 'in_progress'
        && diff.affectedKeys().hasOnly(['status', 'updatedAt'])
        && data.updatedAt == request.time
        && data.title == resource.data.title
        && data.description == resource.data.description
        && data.priority == resource.data.priority
        && data.projectId == resource.data.projectId
        && data.assignedEmployeeId == resource.data.assignedEmployeeId
        && data.createdBy == resource.data.createdBy
        && data.createdAt == resource.data.createdAt
        && data.approvedBy == resource.data.approvedBy
        && data.approvedAt == resource.data.approvedAt;
    }

    function isValidProjectLeaderTaskApproval() {
      let data = request.resource.data;
      let diff = request.resource.data.diff(resource.data);
      return isTaskProjectLeader()
        && resource.data.status == 'pending_approval'
        && data.status == 'approved'
        && diff.affectedKeys().hasOnly(['status', 'approvedBy', 'approvedAt', 'updatedAt'])
        && data.approvedBy == request.auth.uid
        && data.approvedAt == request.time
        && data.updatedAt == request.time
        && data.title == resource.data.title
        && data.description == resource.data.description
        && data.priority == resource.data.priority
        && data.projectId == resource.data.projectId
        && data.assignedEmployeeId == resource.data.assignedEmployeeId
        && data.createdBy == resource.data.createdBy
        && data.createdAt == resource.data.createdAt;
    }

    function isValidProjectLeaderTaskContentUpdate() {
      let data = request.resource.data;
      let diff = request.resource.data.diff(resource.data);
      return isTaskProjectLeader()
        && resource.data.status != 'approved'
        && diff.affectedKeys().hasOnly(['title', 'description', 'priority', 'status', 'assignedEmployeeId', 'updatedAt'])
        && data.title is string
        && data.title.size() > 0
        && data.description is string
        && data.description.size() > 0
        && isValidTaskPriority(data.priority)
        && isValidTaskStatus(data.status)
        && data.status != 'approved'
        && data.assignedEmployeeId is string
        && data.assignedEmployeeId.size() > 0
        && isEmployeeUser(data.assignedEmployeeId)
        && data.updatedAt == request.time
        && data.projectId == resource.data.projectId
        && data.createdBy == resource.data.createdBy
        && data.createdAt == resource.data.createdAt
        && data.approvedBy == resource.data.approvedBy
        && data.approvedAt == resource.data.approvedAt;
    }

    function isValidProjectLeaderTaskUpdate() {
      return isValidProjectLeaderTaskApproval()
        || isValidProjectLeaderTaskRejection()
        || isValidProjectLeaderTaskContentUpdate();
    }

    function isValidTaskUpdate() {
      return isValidEmployeeTaskStatusUpdate()
        || isValidEmployeeTaskUpdatedAtTouch()
        || isValidProjectLeaderTaskUpdate();
    }

    function getTaskData(taskId) {
      return get(/databases/$(database)/documents/Tasks/$(taskId)).data;
    }

    function canReadTaskData(task) {
      return isManagement()
        || (isProjectLeader() && ownsProject(task.projectId))
        || (isEmployee() && task.assignedEmployeeId == request.auth.uid);
    }

    function canReadTask(taskId) {
      return canReadTaskData(getTaskData(taskId));
    }

    function isValidEmployeeStatusTransition(currentStatus, newStatus) {
      return (
        (currentStatus == 'not_started' && newStatus == 'in_progress')
        || (currentStatus == 'in_progress' && newStatus == 'pending_approval')
        || (currentStatus == 'in_progress' && newStatus == 'not_started')
        || (currentStatus == 'pending_approval' && newStatus == 'in_progress')
      );
    }

    function isValidEmployeeUpdateCreate(taskId) {
      let task = getTaskData(taskId);
      let data = request.resource.data;
      let hasStatusChange = data.statusChange != null;
      return isEmployee()
        && task.assignedEmployeeId == request.auth.uid
        && task.status != 'approved'
        && data.keys().hasAll([
          'text',
          'createdBy',
          'createdAt',
          'statusChange',
          'imageUrl',
          'fileUrl',
          'fileName',
        ])
        && data.keys().hasOnly([
          'text',
          'createdBy',
          'createdAt',
          'statusChange',
          'imageUrl',
          'fileUrl',
          'fileName',
        ])
        && data.text is string
        && data.createdBy == request.auth.uid
        && data.createdAt == request.time
        && (data.statusChange == null || isValidTaskStatus(data.statusChange))
        && (
          !hasStatusChange && task.status == 'in_progress'
          || hasStatusChange && isValidEmployeeStatusTransition(task.status, data.statusChange)
        )
        && (data.imageUrl == null || data.imageUrl is string)
        && (data.fileUrl == null || data.fileUrl is string)
        && (data.fileName == null || data.fileName is string)
        && (
          data.text.size() > 0
          || data.imageUrl != null
          || data.fileUrl != null
          || hasStatusChange
        );
    }

    function isValidProjectLeaderUpdateCreate(taskId) {
      let task = getTaskData(taskId);
      let data = request.resource.data;
      return isProjectLeader()
        && ownsProject(task.projectId)
        && task.status == 'pending_approval'
        && data.keys().hasAll([
          'text',
          'createdBy',
          'createdAt',
          'statusChange',
          'imageUrl',
          'fileUrl',
          'fileName',
        ])
        && data.keys().hasOnly([
          'text',
          'createdBy',
          'createdAt',
          'statusChange',
          'imageUrl',
          'fileUrl',
          'fileName',
        ])
        && data.text is string
        && data.text.size() > 0
        && data.createdBy == request.auth.uid
        && data.createdAt == request.time
        && (
          data.statusChange == 'approved'
          || data.statusChange == 'in_progress'
        )
        && data.imageUrl == null
        && data.fileUrl == null
        && data.fileName == null;
    }

    function isValidUpdateCreate(taskId) {
      return isValidEmployeeUpdateCreate(taskId) || isValidProjectLeaderUpdateCreate(taskId);
    }

    function isValidSelfProfileUpdate(userId) {
      let data = request.resource.data;
      let diff = request.resource.data.diff(resource.data);
      return isSelf(userId)
        && diff.affectedKeys().hasOnly(['name', 'email'])
        && data.name is string
        && data.name.size() > 0
        && data.email is string
        && data.email.size() > 0
        && (
          !('role' in resource.data)
          || data.role == resource.data.role
        );
    }

    function isValidManagementUserUpdate() {
      let data = request.resource.data;
      let diff = request.resource.data.diff(resource.data);
      return isManagement()
        && diff.affectedKeys().hasOnly(['name', 'role', 'email'])
        && diff.affectedKeys().size() > 0
        && data.name is string
        && data.name.size() > 0
        && data.email is string
        && data.email.size() > 0
        && isValidRole(data.role);
    }

    match /Users/{userId} {
      allow read: if canReadUser(userId);
      allow create: if isSelf(userId)
        && request.resource.data.keys().hasAll(['email', 'name'])
        && request.resource.data.keys().hasOnly(['email', 'name']);
      allow update: if isValidSelfProfileUpdate(userId) || isValidManagementUserUpdate();
    }

    match /Projects/{projectId} {
      allow read: if isManagement()
        || (isProjectLeader() && resource.data.projectLeaderId == request.auth.uid);
      allow create: if isManagement() && isValidProjectCreate();
      allow update: if (isManagement() && isValidProjectUpdate()) || isValidProjectUpdatedAtTouch();
      allow delete: if false;
    }

    match /Tasks/{taskId} {
      allow read: if isManagement()
        || (isProjectLeader() && ownsProject(resource.data.projectId))
        || (isEmployee() && resource.data.assignedEmployeeId == request.auth.uid);
      allow create: if isProjectLeader() && isValidTaskCreate();
      allow update: if isValidTaskUpdate();
      allow delete: if false;

      match /Updates/{updateId} {
        allow read: if canReadTask(taskId);
        allow create: if isValidUpdateCreate(taskId);
        allow update, delete: if false;
      }
    }
  }
}
