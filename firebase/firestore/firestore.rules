rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/Users/$(request.auth.uid)).data;
    }

    function currentUserRole() {
      return currentUserData().role;
    }

    function isManagement() {
      return signedIn() && currentUserRole() == 'management';
    }

    function isValidRole(role) {
      return role in ['projectLeader', 'management', 'employee'];
    }

    function isProjectLeader() {
      return signedIn() && currentUserRole() == 'projectLeader';
    }

    function isEmployee() {
      return signedIn() && currentUserRole() == 'employee';
    }

    function canReadUser(userId) {
      return isSelf(userId)
        || isManagement()
        || isProjectLeader()
        || (isEmployee() && resource.data.role == 'projectLeader');
    }

    function isValidProjectStatus(status) {
      return status in ['active', 'paused', 'finished'];
    }

    function isProjectLeaderUser(userId) {
      return get(/databases/$(database)/documents/Users/$(userId)).data.role == 'projectLeader';
    }

    function isValidProjectCreate() {
      let data = request.resource.data;
      return data.keys().hasAll(['name', 'description', 'projectLeaderId', 'status', 'createdAt', 'updatedAt'])
        && data.keys().hasOnly(['name', 'description', 'projectLeaderId', 'status', 'createdAt', 'updatedAt'])
        && data.name is string
        && data.name.size() > 0
        && data.description is string
        && data.description.size() > 0
        && data.projectLeaderId is string
        && data.projectLeaderId.size() > 0
        && data.status == 'active'
        && isValidProjectStatus(data.status)
        && isProjectLeaderUser(data.projectLeaderId)
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidProjectUpdate() {
      let data = request.resource.data;
      let diff = request.resource.data.diff(resource.data);
      return diff.affectedKeys().hasOnly(['name', 'description', 'projectLeaderId', 'status', 'updatedAt'])
        && data.name is string
        && data.name.size() > 0
        && data.description is string
        && data.description.size() > 0
        && data.projectLeaderId is string
        && data.projectLeaderId.size() > 0
        && isValidProjectStatus(data.status)
        && isProjectLeaderUser(data.projectLeaderId)
        && data.createdAt == resource.data.createdAt
        && data.updatedAt == request.time;
    }

    function ownsProject(projectId) {
      return get(/databases/$(database)/documents/Projects/$(projectId)).data.projectLeaderId == request.auth.uid;
    }

    function isValidTaskStatus(status) {
      return status in ['not_started', 'in_progress', 'pending_approval', 'approved'];
    }

    function isValidTaskPriority(priority) {
      return priority in ['low', 'medium', 'high', 'critical'];
    }

    function isEmployeeUser(userId) {
      return get(/databases/$(database)/documents/Users/$(userId)).data.role == 'employee';
    }

    function isValidTaskCreate() {
      let data = request.resource.data;
      return data.keys().hasAll([
          'title',
          'description',
          'priority',
          'status',
          'projectId',
          'assignedEmployeeId',
          'createdBy',
          'createdAt',
          'updatedAt',
          'approvedBy',
          'approvedAt',
        ])
        && data.keys().hasOnly([
          'title',
          'description',
          'priority',
          'status',
          'projectId',
          'assignedEmployeeId',
          'createdBy',
          'createdAt',
          'updatedAt',
          'approvedBy',
          'approvedAt',
        ])
        && data.title is string
        && data.title.size() > 0
        && data.description is string
        && data.description.size() > 0
        && isValidTaskPriority(data.priority)
        && isValidTaskStatus(data.status)
        && data.projectId is string
        && data.projectId.size() > 0
        && data.assignedEmployeeId is string
        && data.assignedEmployeeId.size() > 0
        && data.createdBy is string
        && data.createdBy.size() > 0
        && data.createdBy == request.auth.uid
        && isEmployeeUser(data.assignedEmployeeId)
        && ownsProject(data.projectId)
        && data.approvedBy == null
        && data.approvedAt == null
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    match /Users/{userId} {
      allow read: if canReadUser(userId);
      allow create: if isSelf(userId)
        && request.resource.data.keys().hasAll(['email', 'name'])
        && request.resource.data.keys().hasOnly(['email', 'name']);
      allow update: if isManagement()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && isValidRole(request.resource.data.role)
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name'])
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role'])
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'role'])
        );
    }

    match /Projects/{projectId} {
      allow read: if isManagement()
        || (isProjectLeader() && resource.data.projectLeaderId == request.auth.uid);
      allow create: if isManagement() && isValidProjectCreate();
      allow update: if isManagement() && isValidProjectUpdate();
      allow delete: if false;
    }

    match /Tasks/{taskId} {
      allow read: if isManagement()
        || (isProjectLeader() && ownsProject(resource.data.projectId))
        || (isEmployee() && resource.data.assignedEmployeeId == request.auth.uid);
      allow create: if isProjectLeader() && isValidTaskCreate();
      allow update, delete: if false;
    }
  }
}
